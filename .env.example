# Supabase — supabase.com (free tier: 500MB, 50K MAU)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Claude API — console.anthropic.com
# Model: claude-sonnet-4-6 (default) | claude-opus-4-6 (upgrade)
ANTHROPIC_API_KEY=sk-ant-...
AI_COACH_MODEL=claude-sonnet-4-6

# Stripe — dashboard.stripe.com
STRIPE_SECRET_KEY=sk_live_...
STRIPE_WEBHOOK_SECRET=whsec_...
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_live_...
STRIPE_MESSAGE_PACK_PRICE_ID=price_...  # Create: "50 AI Coach Messages" $5.00 one-time

# Resend — resend.com (free tier: 3,000 emails/month)
RESEND_API_KEY=re_...
RESEND_FROM_EMAIL=hello@sidehustlecommandcentre.com

# App URL
NEXT_PUBLIC_APP_URL=https://app.sidehustlecommandcentre.com
